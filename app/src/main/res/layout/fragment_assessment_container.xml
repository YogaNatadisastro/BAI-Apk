<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.form.AssessmentContainerFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white"
        tools:context=".ui.form.AssessmentActivity">

        <!---Progress Stepper -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/white"
                android:elevation="2dp"
                android:padding="16dp"
                tools:ignore="UselessParent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:baselineAligned="false"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!--Step 1: Patient Info-->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/step_1_circle"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/step_circle_active"
                            android:fontFamily="@font/poppins_family"
                            android:text="@string/_1"
                            android:textColor="@color/white"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:textSize="14sp"/>

                        <TextView
                            android:id="@+id/step_1_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/poppins_family"
                            android:text="Patient Info"
                            android:textSize="12sp"
                            android:textColor="#2563EB"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>

                    <View
                        android:id="@+id/connector_1"
                        android:layout_width="0dp"
                        android:layout_height="2dp"
                        android:layout_weight="1"
                        android:background="#E5E7EB"
                        android:layout_marginBottom="15dp"/>

                    <!--Step 2: GAD7-->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/step_2_circle"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/step_circlec_inactive"
                            android:fontFamily="@font/poppins_family"
                            android:text="@string/_2"
                            android:textColor="#6B7280"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:textSize="14sp"/>

                        <TextView
                            android:id="@+id/step_2_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/poppins_family"
                            android:text="GAD7"
                            android:textSize="12sp"
                            android:textColor="#6B7280"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>

                    <!--Connector Line 2-->
                    <View
                        android:id="@+id/connector_2"
                        android:layout_width="0dp"
                        android:layout_height="2dp"
                        android:layout_weight="1"
                        android:background="#E5E7EB"
                        android:layout_marginBottom="15dp"/>

                    <!--Step 3: HADS-->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/step_circlec_inactive"
                            android:fontFamily="@font/poppins_family"
                            android:text="@string/_3"
                            android:textColor="#6B7280"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:textSize="14sp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/poppins_family"
                            android:text="HADS"
                            android:textSize="12sp"
                            android:textColor="#6B7280"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/assessment_viewpager"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:background="@color/white"
                android:elevation="4dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_previous"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/poppins_family"
                    android:text="@string/previous"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    android:layout_marginEnd="8dp"
                    app:strokeWidth="2dp"
                    app:strokeColor="#2563EB"
                    android:backgroundTint="@color/white"
                    app:cornerRadius="8dp"
                    android:textColor="#2563EB"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

                <com.google.android.material.button.MaterialButton
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/poppins_family"
                    android:text="@string/next"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginStart="8dp"
                    android:backgroundTint="#2563EB"
                    app:cornerRadius="8dp"/>
            </LinearLayout>

        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>