<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/white">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="16dp"
        android:background="@color/white"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="#E5E7EB">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Question Text -->
            <TextView
                android:id="@+id/hads_questions_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_family"
                android:text="1. I feel tense of 'wound up'"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#111827"
                android:layout_marginBottom="12dp"/>

            <!-- Response Option -->
            <RadioGroup
                android:id="@+id/hads_radio_group"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Options will be dynamically populated based on question type -->
                <!-- Each HADS question has unique response options -->

                <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/hads_option_0"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins_family"
                    android:text="Option 1"
                    android:textSize="15sp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:paddingStart="8dp"
                    android:background="?attr/selectableItemBackground"
                    app:buttonTint="#D97706"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#F3F4F6"
                    android:layout_marginStart="40dp"/>

                <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/hads_option_1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins_family"
                    android:text="Option 2"
                    android:textSize="15sp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:paddingStart="8dp"
                    android:background="?attr/selectableItemBackground"
                    app:buttonTint="#D97706"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#F3F4F6"
                    android:layout_marginStart="40dp"/>

                <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/hads_option_2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins_family"
                    android:text="Option 3"
                    android:textSize="15sp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:paddingStart="8dp"
                    android:background="?attr/selectableItemBackground"
                    app:buttonTint="#D97706"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#F3F4F6"
                    android:layout_marginStart="40dp"/>

                <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/hads_option_3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins_family"
                    android:text="Option 4"
                    android:textSize="15sp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:paddingStart="8dp"
                    android:background="?attr/selectableItemBackground"
                    app:buttonTint="#D97706"/>
            </RadioGroup>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</androidx.constraintlayout.widget.ConstraintLayout>